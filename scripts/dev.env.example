# Copy this file to scripts/dev.env and customize values for your local environment.
# Values defined here are automatically loaded by init-dev.sh and stop-dev.sh.

# Keycloak administrative credentials used during local provisioning.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=DevStackPassw0rd!

# Optional: override the Grafana port exposed by docker compose.
# GRAFANA_PORT=3001
