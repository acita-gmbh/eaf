# EAF Development Environment Configuration
# Copy this file to .env and adjust values as needed
# All ports are configurable to avoid conflicts with existing services
#
# ⚠️ SECURITY WARNING - DEVELOPMENT ONLY ⚠️
# ===========================================
# The credentials in this file are FOR LOCAL DEVELOPMENT ONLY.
# These simple passwords (admin, eaf_password) are NOT SECURE for production use.
#
# For production deployments:
# - Use proper secrets management (Kubernetes Secrets, HashiCorp Vault, AWS Secrets Manager)
# - Generate strong, unique passwords (minimum 16 characters, mixed case, special chars)
# - Enable TLS/SSL for all services
# - Rotate credentials regularly
# - Never commit .env file to version control (already in .gitignore)
# - Review Keycloak security hardening guide: https://www.keycloak.org/docs/latest/server_admin/#_hardening
#
# DO NOT USE THESE CREDENTIALS IN PRODUCTION ENVIRONMENTS!

# PostgreSQL Configuration
POSTGRES_DB=eaf
POSTGRES_USER=eaf_user
POSTGRES_PASSWORD=eaf_password
POSTGRES_PORT=5432

# Keycloak Configuration
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8080

# Redis Configuration
REDIS_PORT=6379

# Prometheus Configuration
PROMETHEUS_PORT=9090

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3100

# Application Configuration (for future use)
# EAF_APP_PORT=8081
# EAF_PROFILE=dev
