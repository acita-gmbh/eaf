# EAF Development Environment Configuration
# Copy this file to .env and adjust values as needed
# All ports are configurable to avoid conflicts with existing services

# PostgreSQL Configuration
POSTGRES_PORT=5432
POSTGRES_DB=eaf
POSTGRES_USER=eaf_user
POSTGRES_PASSWORD=eaf_password

# Keycloak Configuration
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Redis Configuration
REDIS_PORT=6379

# Prometheus Configuration
PROMETHEUS_PORT=9090

# Grafana Configuration
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Application Configuration (for future use)
# EAF_APP_PORT=8081
# EAF_PROFILE=dev
